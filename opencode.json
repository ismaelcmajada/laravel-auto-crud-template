{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "laravel-boost": {
      "type": "local",
      "enabled": true,
      "command": ["php", "artisan", "boost:mcp"]
    },
    "vuetify-mcp": {
      "type": "remote",
      "url": "https://mcp.vuetifyjs.com/mcp",
      "enabled": true
    }
  }
}
